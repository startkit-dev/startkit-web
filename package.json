{
  "name": "@startkit-dev/startkit",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "clean": "git clean -xdf node_modules/.cache .tanstack .output .nitro dist .wrangler",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB",
    "db:reset": "git clean -xdf .wrangler && pnpm run db:migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "vp dev",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "vp fmt .",
    "format:check": "pnpm run format --check",
    "lint": "vp lint .",
    "lint:fix": "pnpm run lint --fix --fix-suggestions",
    "lint:fixall": "pnpm run lint:fix --fix-dangerously",
    "nuke": "pnpm run clean && git clean -xdf node_modules",
    "outdated": "npx npm-check-updates --interactive --format group",
    "prepare": "vp config",
    "setup": "bin/setup",
    "start": "vp start",
    "test": "vp test",
    "typecheck": "tsc --noEmit --pretty",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router": "^1.168.3",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.5",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotkit": "^1.5.0",
    "drizzle-kit": "^0.31.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.76.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
